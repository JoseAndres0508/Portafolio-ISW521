{
  "name": "whatsapp-chat-hex",
  "version": "1.0.0",
  "description": "Chat en tiempo real sobre WhatsApp aplicando arquitectura hexagonal, DDD y SOLID",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["hexagonal", "ddd", "solid", "whatsapp"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "@whiskeysockets/baileys": "^6.7.9",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/qrcode-terminal": "^0.12.2"
  }
}
